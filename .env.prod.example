# Reference list of production environment variables for Amvera deployment.
#
# This file is documentation only — it is NOT copied or used at deploy time.
# Real values live in Amvera per-application environment settings (one set
# for stilist24-api, one for stilist24-web).
#
# When you add a new variable in Settings (app/core/config.py) that must be
# set in prod:
#   1. Add it here with a comment.
#   2. Add the matching variable to the Amvera application environment.
#
# Migration history: до 2026-04-27 этот файл был референсом для VPS-деплоя
# через docker-compose.prod.yml + GitHub Secrets, .env.prod генерировался CI
# здесь-doc'ом в .github/workflows/deploy.yml. После переезда на Amvera env
# хранится в самом PaaS, .env.prod больше не материализуется на диске.


# =============================================================================
# stilist24-api  (Amvera Docker app, build: ai-stylist-starter/Dockerfile.prod)
# =============================================================================

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
APP_NAME=AI Stylist API
DEBUG=false


# -----------------------------------------------------------------------------
# Postgres — managed service от Amvera. Connection string выдаётся в UI
# Amvera при создании managed Postgres 16. Для psycopg оставляем драйвер
# `postgresql+psycopg`.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://<amvera_pg_user>:<pwd>@<amvera_pg_host>:5432/<db>


# -----------------------------------------------------------------------------
# Redis — managed service от Amvera.
# -----------------------------------------------------------------------------
REDIS_URL=redis://<amvera_redis_host>:6379/0


# -----------------------------------------------------------------------------
# S3 — Yandex Object Storage. Service account с ролью storage.editor,
# статические ключи доступа из Yandex Cloud Console.
# Bucket "ai-stylist" создан вручную, public-read на GET <key>.
# S3_PUBLIC_BASE_URL — публичная база для отдачи фото пользователю.
# Если CNAME media.stilist24.com не настраивали — оставить
# https://storage.yandexcloud.net/ai-stylist (path-style URL).
# -----------------------------------------------------------------------------
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=<yandex_sa_access_key>
S3_SECRET_KEY=<yandex_sa_secret_key>
S3_BUCKET=ai-stylist
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://media.stilist24.com
# storage.editor роль на Yandex Object Storage не даёт прав на bucket policy,
# поэтому делаем объекты публично-читаемыми через per-object canned ACL.
S3_OBJECT_ACL=public-read


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=<secret-32+-bytes-random>
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=60


# -----------------------------------------------------------------------------
# CORS — после переезда на субдомены web и api на разных origin.
# Pydantic-settings парсит CSV (см. _split_cors_csv в app/core/config.py).
# -----------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=https://stilist24.com,https://www.stilist24.com


# -----------------------------------------------------------------------------
# FASHN virtual try-on. Empty key ⇒ stub adapter (deterministic
# placeholder response). Populate to enable the real integration.
# -----------------------------------------------------------------------------
FASHN_API_KEY=
FASHN_BASE_URL=https://api.fashn.ai


# -----------------------------------------------------------------------------
# CV category classifier. ВЫКЛЮЧЕН — OpenAI direct отдаёт 403 с RU-IP.
# Amvera в РФ, проблема не решается переездом. Решение откладываем
# до отдельного плана (kie.ai OpenAI-endpoint / OpenRouter / EU-relay).
# При flag=false классификатор возвращается на heuristic, category=None,
# фронт показывает ручной dropdown.
# -----------------------------------------------------------------------------
USE_CV_CATEGORY_CLASSIFIER=false
CATEGORY_CLASSIFIER_PROVIDER=heuristic
CATEGORY_CONFIDENCE_THRESHOLD=0.6
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5-nano


# =============================================================================
# stilist24-web  (Amvera Docker app, build: frontend/Dockerfile)
# =============================================================================

# NEXT_PUBLIC_* inlined в бандл при `next build` — задаётся как Amvera
# build-arg или environment variable до билда. Менять — пересборка фронта.
NEXT_PUBLIC_API_URL=https://api.stilist24.com
