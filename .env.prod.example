# Reference list of production environment variables for stilist24.com.
#
# Этот файл — справка, не input. Реальный `.env.prod` материализуется CI'ем
# на сервере 194.67.99.214 через here-doc в .github/workflows/deploy.yml
# (шаг "Deploy via SSH"), значения подставляются из GitHub Secrets.
# Локально `.env.prod` нигде не лежит.
#
# Когда добавляете новую обязательную переменную в Settings
# (`ai-stylist-starter/app/core/config.py`):
#   1. Добавить её в этот файл с комментарием.
#   2. Добавить соответствующий GitHub Secret и расширить here-doc в
#      .github/workflows/deploy.yml.

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
APP_NAME=AI Stylist API
DEBUG=false


# -----------------------------------------------------------------------------
# Postgres — контейнер `db` в docker-compose.prod.yml. Пароль приходит из
# GitHub Secret POSTGRES_PASSWORD; БД и пользователь — дефолтные `aistylist`
# и `postgres`. Драйвер `postgresql+psycopg` обязателен (psycopg3).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:<POSTGRES_PASSWORD>@db:5432/aistylist
POSTGRES_DB=aistylist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<random-strong-password>


# -----------------------------------------------------------------------------
# Redis — контейнер `redis` в compose, без auth внутри docker-сети.
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# S3 / MinIO — контейнер `minio` в compose, ключи рутового пользователя
# приходят из GitHub Secrets S3_ACCESS_KEY / S3_SECRET_KEY и одновременно
# являются MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# Bucket создаётся сервисом `createbuckets` при первом старте.
# Публичный доступ — через хостовой nginx, который проксирует
# `/s3/<bucket>/<key>` → `127.0.0.1:9000`. S3_PUBLIC_BASE_URL должен
# включать имя бакета: nginx срезает `/s3/`, а MinIO ждёт `/<bucket>/<key>`.
# -----------------------------------------------------------------------------
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=<random>
S3_SECRET_KEY=<random>
S3_BUCKET=ai-stylist
S3_PUBLIC_BASE_URL=https://stilist24.com/s3/ai-stylist


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=<32+-bytes-random>
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=60


# -----------------------------------------------------------------------------
# FASHN virtual try-on. Пустой ключ ⇒ stub-адаптер (детерминированный
# placeholder-ответ). Реальная интеграция включается заполнением FASHN_API_KEY.
# -----------------------------------------------------------------------------
FASHN_API_KEY=
FASHN_BASE_URL=https://api.fashn.ai


# -----------------------------------------------------------------------------
# CV-классификатор + расширенный vision-анализ. По умолчанию выключены.
#
# USE_CV_CATEGORY_CLASSIFIER — включает определение только категории
# (старая логика, gpt-5-nano или эвристики).
#
# ENABLE_VISION_ANALYSIS — включает один расширенный vision-вызов,
# который за раз возвращает category + name + primary_color + 14
# структурных атрибутов Phase 0. При успехе перекрывает CV_CATEGORY_CLASSIFIER.
#
# OPENAI_BASE_URL — для прокси (OpenRouter/kie.ai/собственный VPN).
# Для api.openai.com напрямую с RU-IP получите 403; на проде нужен прокси.
# -----------------------------------------------------------------------------
USE_CV_CATEGORY_CLASSIFIER=false
ENABLE_VISION_ANALYSIS=false
CATEGORY_CLASSIFIER_PROVIDER=heuristic
CATEGORY_CONFIDENCE_THRESHOLD=0.6
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5-mini
# Прокси для исходящих запросов к OpenAI (обход RU-IP блокировки).
# Схема URL описывает транспорт ДО прокси, не до OpenAI:
#   http://user:pass@host:port    — plain HTTP-прокси
#   https://user:pass@host:port   — HTTPS-прокси (proxy-seller "TXT (https)",
#                                   ISP/residential провайдеры с TLS)
#   socks5://user:pass@host:port  — SOCKS, требует httpx[socks]
# Если ошибочно указать http:// для TLS-прокси → RemoteProtocolError
# 'illegal request line'. Пусто — без прокси.
OPENAI_HTTP_PROXY=


# -----------------------------------------------------------------------------
# Frontend (build-time). NEXT_PUBLIC_* инлайнится в бандл при `next build`.
# В docker-compose.prod.yml пробрасывается в build.args сервиса `web`,
# значение приходит из GitHub Secret NEXT_PUBLIC_API_URL и должно быть
# `https://stilist24.com/api` (хостовой nginx срезает `/api/` и проксирует
# на api-контейнер :8002).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://stilist24.com/api
