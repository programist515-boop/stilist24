# Reference list of production environment variables.
#
# The REAL .env.prod is never copied from this file by hand — it is
# generated on every push to main by .github/workflows/deploy.yml, which
# pulls the secret values from GitHub Secrets and writes .env.prod over
# SSH on the server. Treat this file as documentation of which
# variables exist in production and what they feed.
#
# If you add a new variable in Settings (app/core/config.py) that must
# be set in prod:
#   1. Add it here with a comment.
#   2. Add the matching secret to the GitHub repository.
#   3. Add it to both the `env:` and `envs:` lists in deploy.yml and
#      echo it into the here-doc that writes .env.prod.
#
# Local .env.prod (if you ever need one for a dry run) is gitignored.


# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
APP_NAME=AI Stylist API
DEBUG=false


# -----------------------------------------------------------------------------
# Database — the password is a GitHub secret. DATABASE_URL embeds it, so
# the two lines must match.
# -----------------------------------------------------------------------------
POSTGRES_DB=aistylist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<from GitHub secret POSTGRES_PASSWORD>
DATABASE_URL=postgresql+psycopg://postgres:<POSTGRES_PASSWORD>@db:5432/aistylist


# -----------------------------------------------------------------------------
# Redis — compose-network only.
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# MinIO / S3 — keys are GitHub secrets. The bucket name is hard-coded
# in createbuckets and must equal S3_BUCKET. S3_PUBLIC_BASE_URL points
# at the host nginx prefix, which strips /s3 and proxies to MinIO.
# -----------------------------------------------------------------------------
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=<from GitHub secret S3_ACCESS_KEY>
S3_SECRET_KEY=<from GitHub secret S3_SECRET_KEY>
S3_BUCKET=ai-stylist
S3_PUBLIC_BASE_URL=https://stilist24.com/s3


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=<from GitHub secret JWT_SECRET>
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=60


# -----------------------------------------------------------------------------
# FASHN virtual try-on. Empty key ⇒ stub adapter (deterministic
# placeholder response). Populate to enable the real integration.
# -----------------------------------------------------------------------------
FASHN_API_KEY=<from GitHub secret FASHN_API_KEY, can be blank>
FASHN_BASE_URL=https://api.fashn.ai


# -----------------------------------------------------------------------------
# Next.js — baked into the web image at build time.
# Value in prod is https://stilist24.com/api (nginx strips /api and
# forwards to 127.0.0.1:8002).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=<from GitHub secret NEXT_PUBLIC_API_URL>
